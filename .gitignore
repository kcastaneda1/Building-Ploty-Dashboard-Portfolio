```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/

# Environment variables (CRITICAL)
.env

# MacOS
.DS_Store

# Logs
*.log

# IDEs
.vscode/
.idea/

# Cache
.cache/

# Temporary files
*.tmp

# Data files (optional - include only if NOT needed in repo)
# If your dashboards depend on local data, REMOVE these lines
data/
*.csv
*.xlsx

# SQLite / local DB
*.db

# Distribution files
build/
dist/
*.egg-info/

# Server / deployment
*.pid

# Secrets / keys
*.pem
*.key

# Jupyter
.ipynb_checkpoints/
